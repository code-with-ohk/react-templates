{
	"name": "@ohk/react-template",
	"version": "1.3.0",
	"description": "Minimal React project startups.",
	"keywords": [
		"react",
		"template"
	],
	"main": "app/index.js",
	"type": "module",
	"private": false,
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"crt": "app/index.js"
	},
	"scripts": {
		"start": "node ./app/index.js",
		"deps:check": "node ./app/scripts/sync-template-deps.js",
		"deps:update": "node ./app/scripts/sync-template-deps.js --write"
	},
	"dependencies": {
		"@clack/prompts": "^1.3.0",
		"chalk": "^5.6.2",
		"ejs": "^5.0.2",
		"fs-extra": "^11.3.4",
		"lodash.merge": "^4.6.2"
	},
	"overrides": {
		"minimatch": "^10.2.2"
	},
	"license": "MIT",
	"author": {
		"name": "Ohk Soe Htet",
		"url": "https://ohksoehtet.dev"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-with-ohk/react-templates.git"
	}
}
