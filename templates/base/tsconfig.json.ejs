{
	"include": ["**/*.ts", "**/*.tsx", "eslint.config.js", "prettier.config.js", "vite.config.ts"],
	"compilerOptions": {
		"target": "ES2022",
		"jsx": "react-jsx",
		"module": "ESNext",
		"paths": {
			<% if (addons.includes('tanstack-start')) { %>"#/*": ["./src/*"],
			"@/*": ["./src/*"]<% } else { %>"#/*": ["./src/*"]<% if (addons.includes('shadcn') || addons.includes('tanstack-router')) { %>,
			"@/*": ["./src/*"]
			<% } %><% } %>
		},
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": [
			"vite/client", 
			"node"<% if (addons.includes('react-router')) { %>,
			"vite-plugin-pages/client"
			<% } %>
		],

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		/* Linting */
		"skipLibCheck": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true
	}
}
