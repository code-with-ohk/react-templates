import { defineConfig } from "vite";
<% if (addons.includes('react-router-framework')) { %>
import { reactRouter } from "@react-router/dev/vite";
<% } else { %>
import react from "@vitejs/plugin-react";
<% } %>
<% if (addons.includes('tanstack-router')) { %>
import { tanstackRouter } from "@tanstack/router-plugin/vite";
<% } else if (addons.includes('react-router')) { %>
import Pages from "vite-plugin-pages";
<% } %>
<% if (addons.includes('tailwind')) { %>
import tailwindcss from "@tailwindcss/vite";
<% } %>
<% if (addons.includes('shadcn') || addons.includes('tanstack-router')) { %>
import path from "path";
<% } %>

// https://vite.dev/config/
export default defineConfig({
	plugins: [
		<% if (addons.includes('tanstack-router')) { %>
		tanstackRouter(),
		<% } %>
		<% if (addons.includes('react-router-framework')) { %>
		reactRouter(),
		<% } else { %>
		react(),
		<% } %>
		<% if (!addons.includes('tanstack-router') && addons.includes('react-router')) { %>
		Pages(),
		<% } %>
		<% if (addons.includes('tailwind')) { %>
		tailwindcss(),
		<% } %>
	],
<% if (addons.includes('shadcn') || addons.includes('tanstack-router')) { %>
	resolve: {
		alias: {
			"@": path.resolve(__dirname, "./src"),
		},
	},
	<% } %>
});
