<% if (!queries.reactRouterFramework && !queries.tanstackStart) { %>
import { StrictMode } from "react";
import { createRoot } from "react-dom/client";
import "./index.css";
<% if (queries.tanstackQuery) { %>
import { QueryClientProvider } from "@tanstack/react-query";
import { queryClient } from "./lib/query-client";
<% } %>
<% if (addons.includes('auth-clerk') || addons.includes('auth-supabase') || addons.includes('auth-jwt')) { %>
import { AuthProvider } from "./auth/provider";
<% } %>
<% if (queries.reactRouter || !queries.tanstackRouter) { %>
import App from "./App";
<% } %>

<% if (queries.reactRouter) { %>
import { BrowserRouter } from "react-router-dom";
<% } else if (queries.tanstackRouter) { %>
import { RouterProvider } from "@tanstack/react-router";
import { router } from "./router";
<% } %>

createRoot(document.getElementById("root") as HTMLElement).render(
	<StrictMode>
		<% if (addons.includes('auth-clerk') || addons.includes('auth-supabase') || addons.includes('auth-jwt')) { %>
		<AuthProvider>
		<% } %>
		<% if (queries.tanstackQuery) { %>
		<QueryClientProvider client={queryClient}>
		<% } %>
		<% if (queries.reactRouter) { %>
		<BrowserRouter>
			<App />
		</BrowserRouter>
		<% } else if (queries.tanstackRouter) { %>
		<RouterProvider router={router} />
		<% } else { %>
		<App />
		<% } %>
		<% if (queries.tanstackQuery) { %>
		</QueryClientProvider>
		<% } %>
		<% if (addons.includes('auth-clerk') || addons.includes('auth-supabase') || addons.includes('auth-jwt')) { %>
		</AuthProvider>
		<% } %>
	</StrictMode>
);
<% } %>
