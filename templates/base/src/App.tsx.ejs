<% if (!queries.reactRouterFramework && !queries.tanstackRouter && !queries.tanstackStart) { %>
<% if (queries.reactRouter) { %>
import { Suspense } from "react";
import { useRoutes } from "react-router-dom";
import routes from "~react-pages";

function App() {
	return (
		<Suspense fallback={<div>Loading...</div>}>
			{useRoutes(routes)}
		</Suspense>
	);
}
export default App;
<% } else { %>
<% if (queries.formsRHFZod) { %>
import { RHFZodDemoForm as FormDemo } from "./forms/demo-form";
<% } else if (queries.formsTanStack) { %>
import { TanStackFormDemo as FormDemo } from "./forms/demo-form";
<% } %>

<% if (queries.shadcn) { %>
import { Button } from "@/components/ui/button";
<% } %>

<% if (queries.tanstackQuery) { %>
import { useSuspenseQuery } from "@tanstack/react-query";
<% } %>

<% if (queries.authClerk || queries.authSupabase) { %>
import LoginOrProtectedPanel from "./auth/login-panel";
<% } %>

function Home() {
	<% if (queries.tanstackQuery) { %>
	const { data } = useSuspenseQuery({
		queryKey: ["hello"],
		queryFn: async () => {
			await new Promise((resolve) => setTimeout(resolve, 1000));
			return "TanStack Query is working!";
		},
	});
	<% } %>

	<% if (queries.authClerk || queries.authSupabase) { %>
	return <LoginOrProtectedPanel />;
	<% } else { %>
	return (
		<div className="<%- queries.tailwind ? 'flex h-screen w-full flex-col items-center justify-center gap-4' : '' %>">
			<h1 className="<%- queries.tailwind ? 'text-4xl font-bold tracking-tight' : '' %>">
				Hello World
			</h1>
			<p className="<%- queries.tailwind ? 'text-muted-foreground' : '' %>">
				Work Smart && Hard, !(Hard || Smart)
			</p>

			<% if (queries.tanstackQuery) { %>
			<div className="<%- queries.tailwind ? 'mt-6' : '' %>">
				<p>Query Result: {data}</p>
			</div>
			<% } %>

			<% if (queries.formsRHFZod || queries.formsTanStack) { %>
			<div className="<%- queries.tailwind ? 'mt-6' : '' %>">
				<FormDemo />
			</div>
			<% } %>

			<% if (queries.shadcn) { %>
			<div className="<%- queries.tailwind ? 'flex gap-2 mt-6' : '' %>">
				<Button>Default</Button>
				<Button variant="secondary">Secondary</Button>
				<Button variant="outline">Outline</Button>
				<Button variant="ghost">Ghost</Button>
				<Button variant="destructive">Destructive</Button>
			</div>
			<% } %>
		</div>
	);
	<% } %>
}

function App() {
	return <Home />;
}
export default App;
<% } %>
<% } %>