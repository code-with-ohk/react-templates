	import { createFileRoute, Link } from "@tanstack/react-router";
	<% if (addons.includes('shadcn')) { %>
	import { Button } from "@/components/ui/button";
	<% } %>
	<% if (addons.includes('tanstack-query')) { %>
	import { useSuspenseQuery } from "@tanstack/react-query";
	<% } %>

	export const Route = createFileRoute("/")({ component: Home });

	function Home() {
		<% if (addons.includes('tanstack-query')) { %>
		const { data } = useSuspenseQuery({
			queryKey: ["hello"],
			queryFn: async () => {
				await new Promise((resolve) => setTimeout(resolve, 1000));
				return "TanStack Query is working!";
			},
		});
		<% } %>

		return (
			<div className="<%- addons.includes('tailwind') || addons.includes('shadcn') ? 'p-8' : '' %>">
				<h1 className="<%- addons.includes('tailwind') || addons.includes('shadcn') ? 'text-4xl font-bold tracking-tight' : '' %>">
					Welcome to TanStack Start
				</h1>
				<p className="<%- addons.includes('tailwind') || addons.includes('shadcn') ? 'mt-4 text-lg' : '' %>">
					Edit <code>src/routes/index.tsx</code> to get started.
				</p>

				<% if (addons.includes('tanstack-query')) { %>
				<div className="<%- addons.includes('tailwind') || addons.includes('shadcn') ? 'mt-6' : '' %>">
					<p>Query Result: {data}</p>
				</div>
				<% } %>

				<% if (addons.includes('shadcn')) { %>
				<div className="<%- addons.includes('tailwind') ? 'flex gap-2 mt-6' : '' %>">
					<Button>Default</Button>
					<Button variant="secondary">Secondary</Button>
					<Button variant="outline">Outline</Button>
					<Button variant="ghost">Ghost</Button>
					<Button variant="destructive">Destructive</Button>
				</div>
				<% } %>
					<div className="mt-6">
						<Link to="/about" className="text-blue-500 hover:underline">
							About
						</Link>
					</div>
					<% if (addons.includes('forms-rhf-zod')) { %>
					<div className="mt-2">
						<Link to="/forms-demo" className="text-blue-500 hover:underline">
							Forms Demo
						</Link>
					</div>
					<% } %>
			</div>
		);
	}
