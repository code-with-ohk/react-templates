<% if (queries.reactRouterFramework) { %>
import { RequireAuth } from '@/auth/require-auth';
import { useAuth } from '@/auth/context';

import type { Route } from "./+types/protected";

export function meta({}: Route.MetaArgs) {
  return [
    { title: "Protected Area" },
    { name: "description", content: "Protected page requiring authentication" },
  ];
}

export default function ProtectedPage() {
  return (
    <RequireAuth>
      <ProtectedContent />
    </RequireAuth>
  );
}

function ProtectedContent() {
  const { session, signOut } = useAuth() as any;

  return (
    <div className="flex items-center justify-center min-h-screen bg-background">
      <div className="w-full max-w-md rounded-2xl border border-border bg-background/80 p-6 shadow-sm backdrop-blur">
        <div className="space-y-2">
          <p className="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
            Protected
          </p>
          <h1 className="text-2xl font-semibold tracking-tight">
            Protected Area
          </h1>
          <p className="text-sm text-muted-foreground">
            Only authenticated users can access this page.
          </p>
        </div>
        <div className="mt-6">
          <div>
            <p className="text-sm font-medium text-muted-foreground">Authenticated as:</p>
            <p className="text-lg font-semibold">{session.user?.email}</p>
          </div>
          <button
            onClick={() => signOut()}
            className="mt-4 w-full inline-flex h-10 items-center justify-center rounded-md border border-border bg-secondary px-4 text-sm font-medium transition-colors hover:bg-secondary/80"
          >
            Sign Out
          </button>
        </div>
      </div>
    </div>
  );
}
<% } %>
