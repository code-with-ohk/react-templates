<% if (addons.includes('shadcn')) { %>
import { Button } from "@/components/ui/button";
<% } %>
<% if (addons.includes('forms-rhf-zod') || addons.includes('forms-tanstack')) { %>
import { Link } from "react-router";
<% } %>

import type { Route } from "./+types/home";

export function meta({}: Route.MetaArgs) {
  return [
    { title: "New React Router App" },
    { name: "description", content: "Welcome to React Router!" },
  ];
}

export default function Home() {
  return (
    <div className="<%- addons.includes('tailwind') ? 'flex flex-col items-center justify-center gap-4 py-8' : '' %>">
      <h1 className="<%- addons.includes('tailwind') ? 'text-4xl font-bold tracking-tight' : '' %>">
        Hello World
      </h1>
      <p className="<%- addons.includes('tailwind') ? 'text-muted-foreground' : '' %>">
        Official React Router V7 Framework
      </p>

      <% if (addons.includes('shadcn')) { %>
      <div className="flex gap-2">
        <Button>Default</Button>
        <Button variant="secondary">Secondary</Button>
        <Button variant="outline">Outline</Button>
        <Button variant="ghost">Ghost</Button>
        <Button variant="destructive">Destructive</Button>
      </div>
      <% } %>

      <% if (addons.includes('forms-rhf-zod') || addons.includes('forms-tanstack')) { %>
      <Link className="text-blue-600 hover:underline" to="/forms-demo">
        Go to Forms Demo
      </Link>
      <% } %>
    </div>
  );
}