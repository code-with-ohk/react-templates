import { createRootRoute, Link, Outlet } from "@tanstack/react-router";
<% if (queries.tanstackQuery) { %>
import { QueryClientProvider } from "@tanstack/react-query";
import { queryClient } from "@/lib/query-client";
<% } %>

export const Route = createRootRoute({
	component: () => (
		<% if (queries.tanstackQuery) { %>
		<QueryClientProvider client={queryClient}>
		<% } %>
		<div className="<%- queries.tailwind ? 'p-2 flex gap-2' : '' %>">
			<Link to="/" className="<%- queries.tailwind ? '[&.active]:font-bold' : '' %>">
				Home
			</Link>{' '}
			<Link to="/about" className="<%- queries.tailwind ? '[&.active]:font-bold' : '' %>">
				About
			</Link>
			<hr className="<%- queries.tailwind ? 'my-4' : '' %>" />
			<Outlet />
		</div>
		<% if (queries.tanstackQuery) { %>
		</QueryClientProvider>
		<% } %>
	),
});