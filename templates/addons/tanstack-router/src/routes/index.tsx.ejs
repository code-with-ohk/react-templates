import { Link, createFileRoute } from "@tanstack/react-router";
<% if (queries.shadcn) { %>
import { Button } from "@/components/ui/button";
<% } %>
<% if (queries.tanstackQuery) { %>
import { useSuspenseQuery } from "@tanstack/react-query";
<% } %>

export const Route = createFileRoute("/")({
	component: Home,
});

function Home() {
	<% if (queries.tanstackQuery) { %>
	const { data } = useSuspenseQuery({
		queryKey: ["hello"],
		queryFn: async () => {
			await new Promise((resolve) => setTimeout(resolve, 1000));
			return "TanStack Query is working!";
		},
	});
	<% } %>

	return (
		<div className="<%- queries.tailwind ? 'flex flex-col items-center justify-center gap-4 py-8' : '' %>">
			<h1 className="<%- queries.tailwind ? 'text-4xl font-bold tracking-tight' : '' %>">
				Hello World
			</h1>
			<p className="<%- queries.tailwind ? 'text-muted-foreground' : '' %>">
				Work Smart && Hard, !(Hard || Smart)
			</p>

			<% if (queries.tanstackQuery) { %>
			<div className="<%- queries.tailwind ? 'mt-6' : '' %>">
				<p>Query Result: {data}</p>
			</div>
			<% } %>

			<% if (queries.shadcn) { %>
			<div className="<%- queries.tailwind ? 'flex gap-2 mt-6' : '' %>">
				<Button>Default</Button>
				<Button variant="secondary">Secondary</Button>
				<Button variant="outline">Outline</Button>
				<Button variant="ghost">Ghost</Button>
				<Button variant="destructive">Destructive</Button>
			</div>
			<% } %>

			<% if (addons.includes('forms-rhf-zod') || addons.includes('forms-tanstack')) { %>
			<div className="<%- queries.tailwind ? 'mt-6' : '' %>">
				<Link className="<%- queries.tailwind ? 'text-blue-500 hover:underline' : '' %>" to="/forms-demo">
					Go to Forms Demo
				</Link>
			</div>
			<% } %>

			<% if (addons.includes('auth-clerk')) { %>
			<div className="<%- queries.tailwind ? 'mt-6 flex gap-4' : '' %>">
				<Link className="<%- queries.tailwind ? 'text-blue-500 hover:underline' : '' %>" to="/login">
					Sign In
				</Link>
				<Link className="<%- queries.tailwind ? 'text-blue-500 hover:underline' : '' %>" to="/protected">
					Protected Area
				</Link>
			</div>
			<% } %>
		</div>
	);
}